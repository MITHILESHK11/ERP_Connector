{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI (Run Server)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Pytest (Run All Tests)",
            "type": "debugpy",
            "request": "launch",
            "purpose": ["debug-test"],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
