# The target ERP system to wrapper (must be 'xero' or 'quickbooks')
ERP_TYPE=xero

# The port on which the microservice runs
PORT=8000

# The logging verbosity level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Permitted CORS origins for API consumption (defaults to '*' in dev)
CORS_ORIGIN=*

# The current application version
APP_VERSION=0.1.0

# For testing only — never commit real tokens:
# OAuth access token for Xero sandbox API integration
XERO_TOKEN=your_xero_access_token_here

# Xero tenant/organisation ID (UUID)
XERO_TENANT_ID=your_xero_tenant_id_here

# OAuth access token for QuickBooks Online sandbox API integration
QBO_TOKEN=your_qbo_access_token_here

# QuickBooks Online Realm ID / Company ID
QBO_REALM_ID=your_qbo_realm_id_here
